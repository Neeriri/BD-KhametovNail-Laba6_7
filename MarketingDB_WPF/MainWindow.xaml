<Window x:Class="MarketingDB_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marketing Database - CRUD Operations" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#FF2E2E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Label Grid.Row="0" Content="Лабораторная работа №4 - Marketing DB" 
               FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"
               Foreground="#FFE9CB80"/>

        <!-- Entity Selection -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Выберите сущность:" FontSize="16" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
            <ComboBox x:Name="EntityComboBox" Width="200" FontSize="14" SelectionChanged="EntityComboBox_SelectionChanged">
                <ComboBoxItem Content="Clients"/>
                <ComboBoxItem Content="Campaigns"/>
                <ComboBoxItem Content="Employees"/>
            </ComboBox>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="MainDataGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" Background="#FF6D6D6D" 
                  AlternatingRowBackground="#FF5A5A5A" RowBackground="#FF4A4A4A"
                  Foreground="White" HeadersVisibility="Column"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" SelectedCellsChanged="MainDataGrid_SelectedCellsChanged">
            <DataGrid.Columns>
                <!-- Columns will be set dynamically based on selected entity -->
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="AddButton" Content="Добавить" Width="120" Height="35" 
                    FontSize="14" Background="#FFE9CB80" Margin="10,0" Click="AddButton_Click"/>
            <Button x:Name="EditButton" Content="Изменить" Width="120" Height="35" 
                    FontSize="14" Background="#FFE9CB80" Margin="10,0" Click="EditButton_Click"/>
            <Button x:Name="DeleteButton" Content="Удалить" Width="120" Height="35" 
                    FontSize="14" Background="#FFE9CB80" Margin="10,0" Click="DeleteButton_Click"/>
            <Button x:Name="RefreshButton" Content="Обновить" Width="120" Height="35" 
                    FontSize="14" Background="#FFE9CB80" Margin="10,0" Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
